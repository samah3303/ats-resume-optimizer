generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  name            String?
  email           String   @unique
  passwordHash    String?
  image           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  resumes          Resume[]
  positionProfiles PositionProfile[]
  jobDescriptions  JobDescription[]
  analyses         Analysis[]
  onboardingProfile OnboardingProfile?
  roadmaps          Roadmap[]

  @@map("users")
}

model Resume {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  name       String
  filePath   String?  @map("file_path")
  parsedText String   @map("parsed_text") @db.Text
  isPrimary  Boolean  @default(false) @map("is_primary")
  docType    String?  @map("doc_type")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses           Analysis[]
  onboardingProfiles OnboardingProfile[]
  originalFile       OriginalFile?

  @@map("resumes")
}

model OriginalFile {
  id        String   @id @default(uuid())
  resumeId  String   @unique @map("resume_id")
  data      String   @db.Text
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("original_files")
}

model PositionProfile {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String
  targetRole String   @map("target_role")
  industry   String?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobDescriptions JobDescription[]

  @@map("position_profiles")
}

model JobDescription {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  positionProfileId  String?  @map("position_profile_id")
  title              String
  company            String?
  rawText            String   @map("raw_text") @db.Text
  sourceUrl          String?  @map("source_url")
  notes              String?  @map("notes")
  createdAt          DateTime @default(now()) @map("created_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  positionProfile PositionProfile? @relation(fields: [positionProfileId], references: [id], onDelete: SetNull)
  analyses        Analysis[]

  @@map("job_descriptions")
}

model Analysis {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  resumeId         String?  @map("resume_id")
  jobDescriptionId String   @map("job_description_id")
  overallScore     Int?     @map("overall_score")
  keywordsMatchPct Float?   @map("keywords_match_pct")
  skillsGapJson    String?  @map("skills_gap_json") @db.Text
  formatScore      Int?     @map("format_score")
  impactScore      Int?     @map("impact_score")
  summaryText      String?  @map("summary_text") @db.Text
  rawAiResponse    String   @map("raw_ai_response") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume           Resume?          @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  jobDescription   JobDescription   @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)
  suggestions      Suggestion[]
  sharedAnalyses   SharedAnalysis[]

  @@map("analyses")
}

model Suggestion {
  id            String   @id @default(uuid())
  analysisId    String   @map("analysis_id")
  section       String
  originalText  String   @map("original_text") @db.Text
  suggestedText String   @map("suggested_text") @db.Text
  rationale     String   @db.Text
  accepted      Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("suggestions")
}

model SharedAnalysis {
  id         String   @id @default(uuid())
  analysisId String   @map("analysis_id")
  token      String   @unique
  createdAt  DateTime @default(now()) @map("created_at")

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("shared_analyses")
}

model OnboardingProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  resumeId        String?  @map("resume_id")
  targetPositions String   @map("target_positions") @db.Text
  targetCountry   String   @map("target_country")
  linkedinUrl     String?  @map("linkedin_url")
  portfolioUrl    String?  @map("portfolio_url")
  githubUrl       String?  @map("github_url")
  industry        String?  @map("industry")
  jobType         String?  @map("job_type")
  profileSummary  String?  @map("profile_summary") @db.Text
  coreSkills      String?  @map("core_skills") @db.Text
  marketGaps      String?  @map("market_gaps") @db.Text
  aiSuggestions   String?  @map("ai_suggestions") @db.Text
  linkedinOpts        String?  @map("linkedin_optimizations") @db.Text
  generalAtsScore     Int?     @map("general_ats_score")
  resumeImprovements  String?  @map("resume_improvements") @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@map("onboarding_profiles")
}

model Roadmap {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  strategyOverview String?  @map("strategy_overview") @db.Text
  generatedAt      DateTime @default(now()) @map("generated_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks WeekTask[]

  @@map("roadmaps")
}

model WeekTask {
  id         String @id @default(uuid())
  roadmapId  String @map("roadmap_id")
  weekNumber Int    @map("week_number")
  phase      String
  focusTitle String @map("focus_title")
  tasks      String   @db.Text
  milestone  String

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@map("week_tasks")
}
